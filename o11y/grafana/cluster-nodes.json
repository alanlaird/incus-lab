      "id": 1,
      "type": "timeseries",
      "title": "CPU Usage %",
      "datasource": {
        "type": "prometheus",
        "uid": "incus-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "incus-prometheus"
          },
          "expr": "label_replace(label_replace(label_replace(label_replace(avg without(cpu, mode) (1 - rate(node_cpu_seconds_total{job=\"incus\",mode=\"idle\"}[5m])) * 100, \"node\", \"incus1\", \"instance\", \"172\\\\.16\\\\.11\\\\.141\\\\:8443\"), \"node\", \"incus2\", \"instance\", \"172\\\\.16\\\\.11\\\\.142\\\\:8443\"), \"node\", \"incus3\", \"instance\", \"172\\\\.16\\\\.11\\\\.143\\\\:8443\"), \"node\", \"incus4\", \"instance\", \"172\\\\.16\\\\.11\\\\.144\\\\:8443\")",
          "legendFormat": "{{node}}",
